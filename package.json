{
  "name": "@dan-build/agentstat",
  "version": "0.1.1",
  "description": "Canvas-rendered React component for real-time LLM agent telemetry — live token rates, progress, status transitions, and health scoring.",
  "author": "dan-build",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsup",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vitest run",
    "test:watch": "vitest",
    "publish:beta": "npm publish --tag beta",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/coverage-v8": "^4.1.4",
    "eslint": "^9.39.4",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "globals": "^15.15.0",
    "happy-dom": "^20.9.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tsup": "^8.0.2",
    "typescript": "^5.4.5",
    "typescript-eslint": "^8.58.2",
    "vite": "^6.2.0",
    "vitest": "^4.1.4"
  },
  "keywords": [
    "agent",
    "llm",
    "monitoring",
    "dashboard",
    "react",
    "canvas",
    "visualization",
    "telemetry",
    "observability",
    "agents",
    "ai-sdk",
    "streaming",
    "langchain",
    "vercel-ai",
    "real-time"
  ],
  "homepage": "https://github.com/dan-build/agentstat#readme",
  "bugs": {
    "url": "https://github.com/dan-build/agentstat/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dan-build/agentstat.git"
  }
}
